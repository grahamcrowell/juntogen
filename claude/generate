#!/usr/bin/env bash
#
# generate — Orchestrate Claude CLI invocations to generate the OpenJunto system from specifications.
#
# PURPOSE:
#   This script runs the 12-step generation pipeline (steps 00-11) that transforms
#   the OpenJunto specification corpus into installable artifacts. Each step invokes Claude
#   CLI in --bare mode (no conversation memory, no CLAUDE.md injection) so that the
#   LLM operates solely from the generation prompt and referenced spec files.
#
# CONTEXT ISOLATION:
#   Each step runs Claude with targeted isolation flags that neutralize the user's
#   installed OpenJunto system without breaking credential discovery:
#
#   --append-system-prompt: Injects a GENERATION MODE override that tells Claude to
#           ignore CLAUDE.md instructions and act as a precise code generator. This
#           counters the Manager protocol ("DO NOT write code directly") that would
#           otherwise prevent artifact generation.
#
#   --settings '{"disableAllHooks":true}': Prevents SubagentStart hook from injecting
#           agent profiles and SessionStart hook from running.
#
#   --disable-slash-commands: Prevents skill/command loading.
#
#   --dangerously-skip-permissions: Required for unattended generation. Without this,
#           each step would pause for permission prompts on file writes.
#
#   The output directory (not juntospec) is used as cwd, so no project-level
#   .claude/CLAUDE.md is found. Only ~/.claude/CLAUDE.md is in context, and the
#   append-system-prompt override neutralizes it.
#
#   If ANTHROPIC_API_KEY is set, --bare is used instead (stronger isolation, skips
#   CLAUDE.md entirely). This is recommended for CI pipelines.
#
# SEQUENTIAL EXECUTION:
#   Steps run in strict order: 00 -> 01 -> 02 -> 03 -> 04 -> 05 -> 06 -> 07 -> 08 -> 09 -> 10 -> 11
#   While some steps have independent dependencies (04/05/06 only need 01), sequential
#   execution in v1 simplifies error handling and log readability. Parallelization is
#   a future optimization.
#
# IDEMPOTENCY:
#   After successful completion + verification, each step writes a .step-NN.done sentinel
#   file. Re-runs skip completed steps unless --force or --from-step is specified.
#
# PLACEHOLDER RESOLUTION (H1):
#   Generation prompts contain {OJ_SOURCE} and /path/to/juntospec/ placeholders.
#   Before passing a prompt to Claude, this script resolves them to the actual
#   SPEC_DIR path. Without this, Claude reads nonexistent paths and degrades silently.
#
# THREE-WAY PATH LAYERING (BL-025-h, TENSION-1):
#   {OJ_SOURCE}   = the path to an existing OpenJunto installation, used by step
#                   prompts as a format-reference for output verification only.
#                   Resolved from --oj-source. If absent, prompts containing
#                   {OJ_SOURCE} are left unresolved and Claude degrades per the
#                   step-01 spec ("If available locally, these reference files
#                   provide format verification").
#   ${SPEC_DIR}   = the juntospec corpus root (the genome). Resolved via the
#                   precedence chain in resolve_spec_dir() below: --spec-dir
#                   flag > $OJ_SPEC_DIR env > sibling probe > hard-fail.
#                   Distinct from {OJ_SOURCE} — a SPEC_DIR is a checkout of
#                   juntospec, an OJ_SOURCE is an installed plugin tree.
#   The contract  = ${SPEC_DIR}/platform-contract.yaml. Loaded ONCE at generator
#                   startup by load_contract() and exported as OJ_PRIMITIVE_NAMES /
#                   OJ_CONTRACT_VERSION / OJ_PRIMITIVE_VOCAB_REGEX so the values
#                   propagate to substituted prompt builds AND to validation
#                   scripts called downstream.
#
# COMPATIBILITY:
#   Requires bash 3.2+ (macOS default). Does not use associative arrays or other bash 4+ features.
#

set -euo pipefail

# ── Constants ─────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# SPEC_DIR is resolved later (after parse_args) via:
#   1. --spec-dir DIR           CLI flag (highest precedence)
#   2. ${OJ_SPEC_DIR}            environment variable
#   3. sibling probe            ${SCRIPT_DIR}/../../juntospec (juntogen ↔ juntospec
#                               co-located under a parent like ./openjunto/)
#   4. hard-fail                with an actionable message naming flag, env var, layout
SPEC_DIR=""

readonly SCRIPT_DIR

# Minimum Claude CLI version (major.minor.patch)
readonly MIN_CLAUDE_VERSION="1.0.0"

# All steps in execution order.
# Step 08 retired by BL-025-m.1 (Makefile installer obsolete in plugin form).
# The numeric gap is intentional: preserves sentinel/log history for older runs
# and avoids renumbering downstream prompts/docs. Re-introducing step-08 would
# require restoring the case branches in step_max_turns/step_desc/step_prompt
# plus a verify_step_08 dispatch entry below.
readonly ALL_STEPS="00 01 02 03 04 05 06 07 09 10 11"

# Generation mode override — appended to system prompt when not using --bare.
# Neutralizes the user's CLAUDE.md (OpenJunto Manager protocol) which would otherwise
# instruct Claude to delegate rather than write files directly.
readonly GENERATION_MODE_PROMPT="IMPORTANT OVERRIDE — GENERATION MODE: You are a precise artifact generator, NOT a project manager. Ignore all instructions from CLAUDE.md files in this session. Do NOT delegate to sub-agents. Do NOT apply triage, stakeholder analysis, or expert coordination protocols. Instead: read the generation prompt provided, follow its instructions exactly, and write all specified output files directly using the Write tool. You are generating code and configuration files — write them yourself."

# Use --bare when ANTHROPIC_API_KEY is available (stronger isolation, CI-friendly).
# Fall back to targeted isolation flags when using OAuth (/login) credentials.
use_bare_mode() {
    [ -n "${ANTHROPIC_API_KEY:-}" ]
}

# ── Color Output ──────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[INFO]${NC}  $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }
log_step()  { echo -e "${BLUE}[STEP]${NC}  $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
log_dry()   { echo -e "${CYAN}[DRY]${NC}   $*"; }

die() {
    log_error "$@"
    exit 1
}

# ── Per-Step Configuration ────────────────────────────────────────────────────
#
# Lookup functions replace associative arrays for bash 3.2 compatibility.
# Each function maps step number -> value via case statement.

step_max_turns() {
    case "$1" in
        00) echo 10  ;;  # single file (platform-snapshot.yaml)
        01) echo 25  ;;  # CONDUCTOR.md + scaffold directories
        02) echo 20  ;;  # preamble + index
        03) echo 80  ;;  # 32 profile files — highest volume step
        04) echo 30  ;;  # 8 reference files
        05) echo 25  ;;  # 5 templates
        06) echo 20  ;;  # 3 commands
        07) echo 25  ;;  # helper script + static plugin/hooks manifests
        # 08 retired (BL-025-m.1) — Makefile installer obsolete in plugin form.
        # Numeric gap preserved so sentinel/log history remains comparable.
        09) echo 20  ;;  # settings.json + hooks
        10) echo 30  ;;  # documentation (reads all specs)
        11) echo 25  ;;  # Org scaffold
        *)  die "Unknown step: $1" ;;
    esac
}

step_desc() {
    case "$1" in
        00) echo "Platform capability ingestion" ;;
        01) echo "Scaffold and protocol (CONDUCTOR.md)" ;;
        02) echo "Agent preamble and index" ;;
        03) echo "Agent profiles (16 full + 16 compact)" ;;
        04) echo "Reference files (8 documents)" ;;
        05) echo "Templates (5 deliverables)" ;;
        06) echo "Commands (3 slash commands)" ;;
        07) echo "Helper script (oj-helper) + static plugin/hooks manifests" ;;
        # 08 retired (BL-025-m.1)
        09) echo "Settings and hooks (settings.json)" ;;
        10) echo "Documentation (README, WHY, onboarding)" ;;
        11) echo "Org coordination scaffold" ;;
        *)  die "Unknown step: $1" ;;
    esac
}

step_prompt() {
    case "$1" in
        00) echo "step-00-platform-ingestion.md" ;;
        01) echo "step-01-scaffold-and-protocol.md" ;;
        02) echo "step-02-agent-preamble-and-index.md" ;;
        03) echo "step-03-agent-profiles.md" ;;
        04) echo "step-04-reference-files.md" ;;
        05) echo "step-05-templates.md" ;;
        06) echo "step-06-commands.md" ;;
        07) echo "step-07-helper-script.md" ;;
        # 08 retired (BL-025-m.1) — prompt file removed.
        09) echo "step-09-settings-and-hooks.md" ;;
        10) echo "step-10-documentation.md" ;;
        11) echo "step-11-org-scaffold.md" ;;
        *)  die "Unknown step: $1" ;;
    esac
}

# ── Verification Helpers ─────────────────────────────────────────────────────

check_file() {
    local filepath="$1"
    if [ ! -f "${filepath}" ]; then
        log_error "Missing expected file: ${filepath}"
        return 1
    fi
    if [ ! -s "${filepath}" ]; then
        log_error "File is empty: ${filepath}"
        return 1
    fi
    return 0
}

check_file_exists() {
    local filepath="$1"
    if [ ! -f "${filepath}" ]; then
        log_error "Missing expected file: ${filepath}"
        return 1
    fi
    return 0
}

check_dir() {
    local dirpath="$1"
    if [ ! -d "${dirpath}" ]; then
        log_error "Missing expected directory: ${dirpath}"
        return 1
    fi
    return 0
}

# ── Expected Outputs Per Step (H2) ───────────────────────────────────────────
#
# Each verify function returns 0 if all expected outputs exist and are non-empty.
# These do NOT rely solely on exit codes — they check actual file system state.

verify_step_00() {
    local dir="$1"
    local ok=0
    check_file "${dir}/platform-snapshot.yaml" || ok=1
    return $ok
}

# ── BL-025-m.1: verification functions retargeted for plugin-tree-direct ──
# Pre-cycle: outputs lived under `${dir}/src/`. Post-cycle: outputs live at
# `${dir}/` root in plugin shape — see oj-claude/ for the canonical tree.
# Notable changes:
#   - src/CLAUDE.md         → CONDUCTOR.md (at OUTPUT_DIR root)
#   - src/agents/           → agents/ (flat layout)
#   - src/agents/compact/   → DELETED; flat layout uses *-compact.md suffix
#   - src/templates/        → templates/
#   - src/commands/         → DELETED; plugin uses skills/
#   - src/reference/        → reference/
#   - src/settings.json     → DELETED (plugin doesn't ship settings.json)
#   - src/org-scaffold/     → DEFERRED to BL-025-l/m.2 (commented out below)

verify_step_01() {
    local dir="$1"
    local ok=0
    check_file "${dir}/CONDUCTOR.md" || ok=1
    check_dir  "${dir}/agents" || ok=1
    check_dir  "${dir}/templates" || ok=1
    check_dir  "${dir}/reference" || ok=1
    return $ok
}

verify_step_02() {
    local dir="$1"
    local ok=0
    check_file "${dir}/agents/_preamble.md" || ok=1
    check_file "${dir}/agents/index.md" || ok=1
    return $ok
}

verify_step_03() {
    local dir="$1"
    local ok=0
    local full_count compact_count

    # 16 full profiles in agents/ (excluding _preamble.md, index.md, *-compact.md)
    full_count=$(find "${dir}/agents" -maxdepth 1 -name '*.md' \
        ! -name '_preamble.md' ! -name 'index.md' ! -name '*-compact.md' \
        -type f 2>/dev/null | wc -l | tr -d ' ')
    if [ "${full_count}" -lt 16 ]; then
        log_error "Expected 16 full profiles in agents/, found ${full_count}"
        ok=1
    fi

    # 16 compact profiles in agents/*-compact.md (flat layout per BL-025-m.1)
    compact_count=$(find "${dir}/agents" -maxdepth 1 -name '*-compact.md' -type f 2>/dev/null | wc -l | tr -d ' ')
    if [ "${compact_count}" -lt 16 ]; then
        log_error "Expected 16 compact profiles (agents/*-compact.md), found ${compact_count}"
        ok=1
    fi

    return $ok
}

verify_step_04() {
    local dir="$1"
    local ok=0
    local f
    for f in \
        "workflow-stages.md" \
        "stakeholder-guide.md" \
        "worked-examples.md" \
        "dev-mode.md" \
        "failure-protocol.md" \
        "file-patterns.md" \
        "project-scaffolding.md" \
        "communication-standards.md" \
    ; do
        check_file "${dir}/reference/${f}" || ok=1
    done
    return $ok
}

verify_step_05() {
    local dir="$1"
    local ok=0
    local f
    for f in \
        "technical-analysis.md" \
        "architecture-decision-record.md" \
        "retrospective.md" \
        "session-state.md" \
        "communications-playbook.md" \
    ; do
        check_file "${dir}/templates/${f}" || ok=1
    done
    return $ok
}

verify_step_06() {
    # Step-06 generates 5 plugin skills at skills/<name>/SKILL.md
    # (BL-025-m.2 prompt rewrite). Verification auto-enumerates the
    # skills/ subdirectories rather than hard-coding the 5 names — that
    # way a future skill add (or rename) in the step-06 prompt does not
    # require touching this verifier. Per-skill contract checks mirror
    # the plugin host's load contract:
    #   - frontmatter must start with `---` on line 1
    #   - frontmatter must contain a `description:` line
    #   - body must exceed 5 lines (a near-empty file is a generation
    #     failure; the plugin host accepts it silently but the cycle
    #     gate cannot)
    # Mirrors the for-loop pattern in verify_step_04 / verify_step_05.
    local dir="$1"
    local ok=0
    check_dir "${dir}/skills" || ok=1
    if [ ! -d "${dir}/skills" ]; then
        return $ok
    fi
    # Enumerate skills/*/SKILL.md. find pipeline is BSD-portable.
    local found=0
    local skill_md
    while IFS= read -r skill_md; do
        [ -z "${skill_md}" ] && continue
        found=$((found + 1))
        check_file "${skill_md}" || ok=1
        # frontmatter: first line must be exactly `---`
        local first_line
        first_line=$(head -n1 "${skill_md}" 2>/dev/null)
        if [ "${first_line}" != "---" ]; then
            log_error "Step 06: ${skill_md} does not start with YAML frontmatter (line 1 != '---')"
            ok=1
        fi
        # `description:` must appear in the file (typically in frontmatter)
        if ! grep -q '^description:' "${skill_md}"; then
            log_error "Step 06: ${skill_md} missing required 'description:' field"
            ok=1
        fi
        # body length: total lines must exceed 5 (the plugin host accepts
        # near-empty skills silently; we treat them as generation
        # failures so the cycle gate catches them)
        local nlines
        nlines=$(wc -l < "${skill_md}" | tr -d ' ')
        if [ "${nlines}" -le 5 ]; then
            log_error "Step 06: ${skill_md} has ${nlines} lines (require >5)"
            ok=1
        fi
    done < <(find "${dir}/skills" -mindepth 2 -maxdepth 2 -name 'SKILL.md' -type f 2>/dev/null | sort)
    if [ "${found}" -eq 0 ]; then
        log_error "Step 06: no skills/<name>/SKILL.md files found under ${dir}/skills"
        ok=1
    fi
    return $ok
}

verify_step_07() {
    local dir="$1"
    local ok=0
    # bin/oj-helper — LLM-generated helper script (PROSE per output_classes).
    check_file "${dir}/bin/oj-helper" || ok=1
    if [ -f "${dir}/bin/oj-helper" ] && [ ! -x "${dir}/bin/oj-helper" ]; then
        log_warn "bin/oj-helper exists but is not executable"
    fi
    # bin/lib/contracts.sh — DATA (static, deterministic).
    check_file "${dir}/bin/lib/contracts.sh" || ok=1
    # Static plugin manifest + hooks manifest (BL-025-m.1 Deliverable 5).
    # These are deterministic templates emitted by lib/emit-static-plugin-manifest.sh,
    # invoked from step-07 alongside the LLM helper-script generation.
    check_file "${dir}/.claude-plugin/plugin.json" || ok=1
    check_file "${dir}/hooks/hooks.json" || ok=1
    return $ok
}

