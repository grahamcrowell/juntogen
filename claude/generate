# Dispatch to the correct verify function. Step-08 dispatch removed (BL-025-m.1).
verify_step() {
    local step="$1"
    local dir="$2"
    case "${step}" in
        00) verify_step_00 "${dir}" ;;
        01) verify_step_01 "${dir}" ;;
        02) verify_step_02 "${dir}" ;;
        03) verify_step_03 "${dir}" ;;
        04) verify_step_04 "${dir}" ;;
        05) verify_step_05 "${dir}" ;;
        06) verify_step_06 "${dir}" ;;
        07) verify_step_07 "${dir}" ;;
        # 08 retired (BL-025-m.1)
        09) verify_step_09 "${dir}" ;;
        10) verify_step_10 "${dir}" ;;
        11) verify_step_11 "${dir}" ;;
        *)  log_warn "No verification function for step ${step}"; return 0 ;;
    esac
}

# ── Static-Artifact Emit Dispatch (BL-025-m.2) ────────────────────────
# After a step's LLM invocation succeeds (Claude exit 0) but BEFORE
# verify_step() runs, dispatch to the static-emit helper for any DATA-
# class artifacts that step is responsible for. The helper writes
# byte-deterministic files alongside the LLM output; the verifier then
# sees both as a single coherent step output.
#
# Currently only step-07 has DATA-class siblings (plugin.json +
# marketplace.json + hooks.json + bin/lib/contracts.sh +
# platform-defaults.yaml). The helper functions live in
# lib/emit-static-plugin-manifest.sh — sourced lazily here so the
# generator startup cost stays unchanged when no static emit fires.
#
# Mirrors verify_step() dispatch pattern. Failure to source the helper
# OR a non-zero exit from any emit function aborts the step with a
# clear error (matches the verifier's fail-loud contract).
static_artifacts_emit() {
    local step="$1"
    local dir="$2"
    case "${step}" in
        07)
            local helper="${SCRIPT_DIR}/lib/emit-static-plugin-manifest.sh"
            if [ ! -f "${helper}" ]; then
                log_error "static_artifacts_emit: helper not found at ${helper}"
                return 1
            fi
            # Source the helper to expose emit_plugin_json /
            # emit_marketplace_json / emit_hooks_json / emit_contracts_sh /
            # emit_platform_defaults. Sourcing in a subshell would scope the
            # functions away; the generator script is bash, so sourcing
            # here is safe — the helper declares no top-level state that
            # would conflict with the generator.
            # shellcheck source=/dev/null
            . "${helper}" || { log_error "static_artifacts_emit: failed to source ${helper}"; return 1; }
            # VERSION resolution: prefer SPEC_DIR/VERSION (the genome's
            # source-of-truth) and fall back to a static 0.0.1 when
            # absent (m.2 spike mode). The version flows into the
            # plugin.json's `"version":` field — m.3 will tighten the
            # fallback path.
            local version="0.0.1"
            if [ -f "${SPEC_DIR}/VERSION" ]; then
                version=$(head -n1 "${SPEC_DIR}/VERSION" | tr -d ' \r\n\t')
            fi
            emit_plugin_json       "${dir}" "${version}" >/dev/null \
                || { log_error "static_artifacts_emit: emit_plugin_json failed"; return 1; }
            emit_marketplace_json  "${dir}"              >/dev/null \
                || { log_error "static_artifacts_emit: emit_marketplace_json failed"; return 1; }
            emit_hooks_json        "${dir}"              >/dev/null \
                || { log_error "static_artifacts_emit: emit_hooks_json failed"; return 1; }
            emit_contracts_sh      "${dir}"              >/dev/null \
                || { log_error "static_artifacts_emit: emit_contracts_sh failed"; return 1; }
            emit_platform_defaults "${dir}"              >/dev/null \
                || { log_error "static_artifacts_emit: emit_platform_defaults failed"; return 1; }
            # Hand-cut scripts/ tree (validate-plugin.sh + scripts/tests/*) —
            # NOT regenerated by the LLM; static-copied from OJ_CLAUDE_DIR
            # so the regen tree carries the plugin-side test harness. Failure
            # is non-fatal if OJ_CLAUDE_DIR is unset/unavailable (spike-mode
            # and disconnected runs are still useful for the LLM artifacts).
            if ! emit_plugin_scripts "${dir}" >/dev/null 2>&1; then
                log_warn "  emit_plugin_scripts: source not found (OJ_CLAUDE_DIR=${OJ_CLAUDE_DIR:-unset}); skipping"
            fi
            log_ok "  Static manifests emitted (plugin.json, marketplace.json, hooks.json, bin/lib/contracts.sh, platform-defaults.yaml; scripts/ copied if available)"
            ;;
        *)
            # No-op for steps without DATA-class siblings.
            return 0
            ;;
    esac
}

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
$(echo -e "${BOLD}")generate$(echo -e "${NC}") — Generate the OpenJunto system from specifications via Claude CLI.

$(echo -e "${BOLD}")USAGE$(echo -e "${NC}")
    generate <OUTPUT_DIR> [OPTIONS]

$(echo -e "${BOLD}")ARGUMENTS$(echo -e "${NC}")
    OUTPUT_DIR                 Target directory for generated artifacts (required).
                               Created if it does not exist. All Claude invocations
                               use this as their working directory.

$(echo -e "${BOLD}")OPTIONS$(echo -e "${NC}")
    --model MODEL              Claude model to use (default: opus).
    --from-step NN             Resume from step NN, ignoring prior sentinels.
    --steps 00,04,05           Run only the specified steps (comma-separated).
                               Skips dependency checking — assumes operator knows
                               what they are doing.
    --platform-declaration F   Copy FILE to OUTPUT_DIR/platform-declaration.yaml
                               before step-00, enabling CI-reproducible declaration
                               mode.
    --oj-source DIR            Path to an existing OpenJunto installation for step-10
                               format-reference reads (/path/to/openjunto/ placeholders).
                               If omitted, those placeholders are left unresolved
                               and Claude degrades gracefully per step-01 spec.
    --spec-dir DIR             Path to the juntospec corpus root. Overrides
